# ========== 数据库 ==========
# 本地 PostgreSQL；需先安装 pgvector 扩展（见 README）
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/exotic_pet_ai?schema=public"

# ========== 鉴权 ==========
# 用于签发 session JWT，随便一段长随机字符串
AUTH_SECRET="change-me-to-a-long-random-string"

# ========== 大模型（通义千问 Qwen-VL / DashScope）==========
# 留空则自动降级为 mock 实现，主流程仍可跑通
LLM_PROVIDER="qwen"            # qwen | mock
DASHSCOPE_API_KEY=""
QWEN_VL_MODEL="qwen-vl-max"
# DashScope OpenAI 兼容端点
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# ========== 短信（阿里云短信）==========
# 留空则自动降级为固定验证码 mock（见 README，开发期用 000000）
SMS_PROVIDER="mock"           # aliyun | mock
ALIYUN_SMS_ACCESS_KEY_ID=""
ALIYUN_SMS_ACCESS_KEY_SECRET=""
ALIYUN_SMS_SIGN_NAME=""
ALIYUN_SMS_TEMPLATE_CODE=""

# ========== 高德地图 ==========
# Web 服务 API（后端地点检索）
AMAP_WEB_SERVICE_KEY=""
# Web 端 JS API（前端地图展示），暴露给浏览器
NEXT_PUBLIC_AMAP_JS_KEY=""
